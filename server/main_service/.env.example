# Backend FastAPI + Management gRPC 환경변수 템플릿
# 실제 값은 .env.local 에 작성 (.gitignore 가 .env*.local 차단).
# 팀장에게 RDS 비밀번호와 엔드포인트를 받아주세요.

# AWS RDS Casting (활성 DB) — sslrootcert 는 절대 경로
DATABASE_URL="postgresql+psycopg://postgres:<PASSWORD>@<RDS_ENDPOINT>:5432/Casting?sslmode=verify-full&sslrootcert=/absolute/path/to/global-bundle.pem"

# 사용 스키마 — AWS RDS 는 public, 로컬 Tailscale 은 smartcast
SMARTCAST_SCHEMA=public

# (선택) APP_ENV 가 development 일 때만 /api/debug/* endpoint 활성화
APP_ENV=development

# (선택) Mgmt gRPC ROS2 어댑터 — Mgmt 서버 별도 기동 시 1
MGMT_ROS2_ENABLED=0

# (선택) Interface ↔ Management proxy — V6 Phase C-2 호환 모드
INTERFACE_PROXY_START_PRODUCTION=0
