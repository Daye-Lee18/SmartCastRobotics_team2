# PyQt Monitoring 환경변수 템플릿
# 실제 값은 .env.local 또는 셸에서 export.

# Backend FastAPI 주소 (기본: http://localhost:8000)
API_BASE_URL=http://localhost:8000

# 데이터 모드
#   real        — 백엔드만 사용 (빈 응답 시 빈 화면)
#   fallback    — 백엔드 호출 + 실패/빈 시 mock 데이터로 대체 (기본)
#   mock_only   — 백엔드 호출 안 하고 mock 만 사용 (오프라인 데모)
CASTING_DATA_MODE=fallback

# (선택) Mgmt gRPC 사용 시
MGMT_GRPC_ADDRESS=localhost:50051
